# OpenDART API 키 (https://opendart.fss.or.kr/intro/main.do)
OPENDART_API_KEY=your_opendart_api_key_here

# Google Gemini API 키 (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# 데이터 저장 경로
# 로컬 개발: ./data  |  Docker: /app/data (기본값)
DATA_DIR=./data

# 서버 포트
BACKEND_PORT=8016
FRONTEND_PORT=8097

# 스케줄러: 신규 사업보고서 자동 수집 주기 (시간)
SCHEDULER_INTERVAL_HOURS=24

# Gemini 호출 간격 (초) — TPM 한도 대응 (gemini-3-flash-preview: 2M TPM)
ANALYSIS_INTERVAL_SECS=30
